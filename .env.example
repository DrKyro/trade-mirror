VITE_BASE_URL=http://localhost:3000
BETTER_AUTH_TRUSTED_ORIGINS=

DATABASE_URL="postgresql://postgres:password@localhost:5432/tanstarter"
# You can also use Docker Compose to set up a local PostgreSQL database:
# docker-compose up -d

# pnpm run auth:secret
BETTER_AUTH_SECRET=

# OAuth2 providers, optional, update as needed
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional exchange credentials for live teacher execution / live trader refresh
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_API_PASSWORD=
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSWORD=

# Optional browser-copied OKX headers for copy-trading rank endpoint
# These come from a logged-in browser request and expire; copy from DevTools > Network
OKX_AUTHORIZATION=
OKX_X_CLIENT_SIGNATURE=
OKX_X_CLIENT_SIGNATURE_VERSION=
OKX_X_REQUEST_TIMESTAMP=
OKX_X_SITE_INFO=
OKX_COOKIE=
OKX_DEVID=
BINANCE_API_KEY=
BINANCE_API_SECRET=
HUOBI_API_KEY=
HUOBI_API_SECRET=
HUOBI_API_PASSWORD=
BYBIT_API_USERTOKEN=
BYBIT_API_COOKIE=
BYBIT_PUPPETEER_EXECUTABLE_PATH=
BYBIT_PUPPETEER_HEADLESS=true
BYBIT_PUPPETEER_USER_DATA_DIR=
BYBIT_PUPPETEER_SCREENSHOT_DIR=./logs

# Optional notification sinks migrated from traderSpy / FollowTraderManager
ALERT_FEISHU_WEBHOOK_URL=
ALERT_FEISHU_APP_ID=
ALERT_FEISHU_APP_SECRET=
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=
ALERT_DISCORD_WEBHOOK_URL=
ALERT_NOTIFY_TRADER_CHANGES=true
ALERT_NOTIFY_WARNINGS=true
ALERT_NOTIFY_STARTUP=false
ALERT_ROUTE_DEFAULT=feishu,telegram,discord
ALERT_ROUTE_TRADER_CHANGE=feishu,telegram,discord
ALERT_ROUTE_RUNTIME_WARNING=feishu,telegram,discord
ALERT_ROUTE_STARTUP=feishu,telegram,discord
ALERT_ROUTE_BYBIT_ATTENTION=feishu,telegram,discord

# NOTE:
# In your OAuth2 apps, set callback/redirect URIs to`http://localhost:3000/api/auth/callback/<provider>`
# e.g. http://localhost:3000/api/auth/callback/github
